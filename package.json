{
  "name": "marlonii-web",
  "private": true,
  "type": "module",
  "workspaces": [
    "www",
    "blog",
    "minimal",
    "scripts"
  ],
  "overrides": {
    "vite": "^7.3.1"
  },
  "scripts": {
    "build": "npm run build:scripts && npm run build:www && npm run build:blog && npm run build:minimal",
    "build:scripts": "npm -w marlonii-shared-scripts run build",
    "build:www": "npm -w www run build",
    "build:blog": "npm -w blog run build",
    "build:minimal": "npm -w minimal run build",
    "dev:www": "npm -w www run dev",
    "dev:blog": "npm -w blog run dev",
    "dev:minimal": "npm -w minimal run dev"
  }
}

