---
import MinimalLayout from '../layouts/MinimalLayout.astro';
import { getFileById } from '../config/index';

const url = new URL(Astro.request.url);
const fileId = url.searchParams.get('file') || 'home';
const activeFile = getFileById(fileId);
---

<MinimalLayout>
	<section class="editor-section relative flex min-h-[calc(100vh-5rem)] flex-col lg:min-h-[calc(100vh-3.5rem)]">
		<div class="editor-content-area flex-1 overflow-auto p-4 font-jetbrains-mono text-sm leading-6 text-[#abb2bf]">
			<Fragment set:html={activeFile.content} />
		</div>
	</section>
</MinimalLayout>

<style>
	.editor-section {
		font-family: 'JetBrains Mono', monospace;
	}
	.editor-content-area {
		scrollbar-width: thin;
		scrollbar-color: color-mix(in srgb, var(--color-skyBlue) 25%, transparent) transparent;
	}
	.editor-content-area::-webkit-scrollbar {
		width: 8px;
		height: 8px;
	}
	.editor-content-area::-webkit-scrollbar-thumb {
		background: color-mix(in srgb, var(--color-sky-blue) 25%, transparent);
		border-radius: 999px;
	}
</style>
