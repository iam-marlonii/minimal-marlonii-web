---
import { getIcon } from '../../config/icons';
import Terminal from '../terminal/Terminal.astro';
import MarlonIIColorLogo from '../../assets/logos/marlonii-ColorLogo.svg?url';
---

<div
	id="sidebar-backdrop"
	class="sidebar-backdrop fixed inset-0 z-210 bg-black/55 opacity-0 pointer-events-none transition-opacity duration-200 lg:z-100 lg:hidden"
	aria-hidden="true"
></div>

<button
	type="button"
	id="sidebar-open"
	class="sidebar-fab fixed bottom-4 left-4 z-220 flex h-12 w-12 items-center justify-center rounded-full border-2 border-(--color-skyBlue)/50 bg-black/90 text-(--color-skyBlue) shadow-lg backdrop-blur-sm transition-colors hover:border-(--color-skyBlue) hover:bg-(--color-skyBlue)/10 lg:hidden"
	aria-expanded="false"
	aria-controls="minimal-sidebar-panel"
>
	<span class="sr-only">Open site menu</span>
	<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="h-5 w-5" fill="currentColor" aria-hidden="true">
		<path
			d="M64 128C64 110.3 78.3 96 96 96L544 96C561.7 96 576 110.3 576 128C576 145.7 561.7 160 544 160L96 160C78.3 160 64 145.7 64 128zM64 320C64 302.3 78.3 288 96 288L544 288C561.7 288 576 302.3 576 320C576 337.7 561.7 352 544 352L96 352C78.3 352 64 337.7 64 320zM64 512C64 494.3 78.3 480 96 480L544 480C561.7 480 576 494.3 576 512C576 529.7 561.7 544 544 544L96 544C78.3 544 64 529.7 64 512z"
		></path>
	</svg>
</button>

<aside
	id="minimal-sidebar-panel"
	class="sidebar-panel fixed left-0 top-0 z-210 flex h-screen w-64 max-w-[min(280px,calc(100vw-1rem))] flex-col border-r border-(--color-skyBlue)/30 bg-[#050a10]/95 pb-6 shadow-[4px_0_24px_rgba(0,0,0,0.35)] backdrop-blur-md lg:z-105"
	aria-label="Site navigation"
>
	<div class="flex h-16 shrink-0 items-center gap-2 border-b border-(--color-skyBlue)/30">
        <div class="flex min-h-0 min-w-0 flex-1 items-center justify-between px-4">
            <div class="flex items-center gap-2 text-white transition-opacity hover:opacity-90">
                <span class="">EXPLORER</span>
            </div>
            <button
				type="button"
            	id="terminal-toggle"
				aria-expanded="false"
				aria-controls="terminal-dropdown"
            	class="relative flex items-center justify-center h-8 w-8 z-10 p-1 cursor-pointer gap-2 text-sm bg-black border-2 rounded-full border-(--color-skyBlue)/40 hover:border-(--color-skyBlue) transition-colors duration-200">
            	<span class="w-4 h-4 flex shrink-0 text-white" set:html={getIcon('terminal')} />
        	</button>
        </div>
		<button
			type="button"
			id="sidebar-close"
			class="ml-auto flex h-9 w-9 items-center justify-center rounded-full border border-(--color-skyBlue)/40 text-(--color-skyBlue) transition-colors hover:bg-(--color-skyBlue)/15 lg:hidden"
			aria-label="Close site menu"
		>
			<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 640 640" class="h-4 w-4" fill="currentColor">
				<path
					d="M180.1 137.7C191.4 126.4 209.6 126.4 220.9 137.7L320 236.7L419.1 137.7C430.4 126.4 448.6 126.4 459.9 137.7C471.2 148.9 471.2 167.2 459.9 178.5L360.8 277.5L459.9 376.6C471.2 387.9 471.2 406.1 459.9 417.4C448.6 428.7 430.4 428.7 419.1 417.4L320 318.3L220.9 417.4C209.6 428.7 191.4 428.7 180.1 417.4C168.8 406.1 168.8 387.9 180.1 376.6L279.2 277.5L180.1 178.5C168.8 167.2 168.8 148.9 180.1 137.7z"
				></path>
			</svg>
		</button>
	</div>

	<nav class="sidebar-scroll flex min-h-0 flex-col gap-6 overflow-y-auto overscroll-contain px-4 mt-4 font-jetbrains-mono">
        <details open class="sidebar-section">
            <summary class="sidebar-section-title flex cursor-pointer list-none flex-row items-center gap-2 [&::-webkit-details-marker]:hidden">
                <span
                    class="sidebar-disclosure-caret flex h-3.5 w-3.5 shrink-0 items-center justify-center"
                    aria-hidden="true"
                    set:html={getIcon('chevron-down')}
                />
                <span class="relative h-4 w-4 shrink-0 text-(--color-gray)" aria-hidden="true">
                    <span
                        class="sidebar-folder-icon-open absolute inset-0 flex items-center justify-center[&_svg]:h-full [&_svg]:w-full"
                        set:html={getIcon('folder-open')}
                    />
                    <span
                        class="sidebar-folder-icon-closed absolute inset-0 flex items-center justify-center[&_svg]:h-full [&_svg]:w-full"
                        set:html={getIcon('folder-closed')}
                    />
                </span>
                MARLON_AUSBY_II
            </summary>
            <ul class="sidebar-section-list ml-6">
                <li>
                    <a href="/" class="sidebar-section-link flex flex-row items-center gap-2 ">
                        <span class="w-4 h-4 flex shrink-0 text-(--color-skyBlue)" set:html={getIcon('file-text')} />
                        home.md
                    </a>
                </li>
                <li>
                    <a href="/" class="sidebar-section-link flex flex-row items-center gap-2 ">
                        <span class="w-4 h-4 flex shrink-0 text-[#3a86ff]" set:html={getIcon('code')} />
                        experience.ts
                    </a>
                </li>
                <li>
                    <a href="/" class="sidebar-section-link flex flex-row items-center gap-2 ">
                        <span class="w-4 h-4 flex shrink-0 text-[#ff8fab]" set:html={getIcon('palette')} />
                        education.css
                    </a>
                </li>
                <li>
                    <a href="/" class="sidebar-section-link flex flex-row items-center gap-2 ">
                        <span class="w-4 h-4 flex shrink-0 text-[#ffbe0b]" set:html={getIcon('sql')} />
                        projects.sql
                    </a>
                </li>
                <li>
                    <a href="/" class="sidebar-section-link flex flex-row items-center gap-2 ">
                        <span class="w-4 h-4 flex shrink-0 text-[#ffe6a7]" set:html={getIcon('globe')} />
                        contact.html
                    </a>
                </li>
                <li>
                    <a href="/" class="sidebar-section-link flex flex-row items-center gap-2 ">
                        <span class="w-4 h-4 flex shrink-0 text-(--color-vermilion)" set:html={getIcon('download-file')} />
                        resume.pdf
                    </a>
                </li>
            </ul>
        </details>

	</nav>
</aside>

<!-- Terminal: bottom sheet (outside aside so it isn’t clipped by sidebar stacking/overflow) -->
<div
	id="terminal-sheet-backdrop"
	class="terminal-sheet-backdrop fixed inset-0 z-230 bg-black/55 opacity-0 pointer-events-none transition-opacity duration-300"
	aria-hidden="true"
></div>
<div
	id="terminal-dropdown"
	class="terminal-sheet-panel pointer-events-none fixed inset-x-0 bottom-0 z-231 flex justify-center px-2 pt-2 pb-[max(0.5rem,env(safe-area-inset-bottom))] sm:px-4 sm:pb-[max(0.75rem,env(safe-area-inset-bottom))]"
	role="dialog"
	aria-modal="true"
	aria-labelledby="terminal-sheet-title"
	aria-hidden="true"
>
	<div
		class="terminal-sheet-surface flex w-full max-w-5xl flex-col overflow-hidden rounded-t-2xl border border-(--color-skyBlue)/35 border-b-0 bg-[#050a10]/98 shadow-[0_-8px_40px_rgba(0,0,0,0.45)] backdrop-blur-md lg:max-w-6xl"
	>
		<div class="flex shrink-0 flex-col gap-2 border-b border-(--color-skyBlue)/20 px-3 pb-3 pt-2 sm:px-4 sm:pb-3 sm:pt-2.5">
			<div class="mx-auto h-1 w-10 shrink-0 rounded-full bg-(--color-skyBlue)/25" aria-hidden="true"></div>
			<div class="flex items-center justify-between gap-3">
				<h2 id="terminal-sheet-title" class="text-sm font-medium tracking-wide text-white sm:text-base">Terminal</h2>
				<button
					type="button"
					id="terminal-sheet-close"
					class="flex h-9 w-9 shrink-0 cursor-pointer items-center justify-center rounded-full border-2 border-(--color-skyBlue)/40 text-(--color-skyBlue) transition-colors hover:border-(--color-skyBlue)"
					aria-label="Close terminal"
				>
					<span class="w-4 h-4 flex shrink-0 text-white" set:html={getIcon('xmark')} />
				</button>
			</div>
		</div>
		<div class="terminal-sheet-body flex min-h-0 w-full flex-1 flex-col overflow-hidden px-2 pb-3 pt-0 sm:px-3 md:px-4">
			<Terminal client:idle />
		</div>
	</div>
</div>

<style>
	.sidebar-panel {
		transform: translateX(-100%);
		transition: transform 200ms ease-out;
	}
	@media (min-width: 1024px) {
		.sidebar-panel {
			transform: translateX(0);
		}
	}
	.sidebar-panel.is-open {
		transform: translateX(0);
	}
	.sidebar-backdrop.is-visible {
		opacity: 1;
		pointer-events: auto;
	}
	.sidebar-scroll {
		scrollbar-width: thin;
		scrollbar-color: color-mix(in srgb, var(--color-skyBlue) 35%, transparent) transparent;
	}
	.sidebar-scroll::-webkit-scrollbar {
		width: 6px;
	}
	.sidebar-scroll::-webkit-scrollbar-thumb {
		background: color-mix(in srgb, var(--color-skyBlue) 35%, transparent);
		border-radius: 999px;
	}
	:global(.sidebar-open) {
		overflow: hidden;
	}
	@media (min-width: 1024px) {
		:global(.sidebar-open) {
			overflow: auto;
		}
	}

	/* Details: custom caret + folder icons (hide native disclosure marker) */
	.sidebar-section summary {
		list-style: none;
	}
	.sidebar-section summary::-webkit-details-marker {
		display: none;
	}
	.sidebar-disclosure-caret :global(svg) {
		display: block;
		transform-origin: center;
		transition: transform 0.15s ease;
	}
	.sidebar-section:not([open]) .sidebar-disclosure-caret :global(svg) {
		transform: rotate(-90deg);
	}
	.sidebar-section[open] .sidebar-folder-icon-closed {
		display: none;
	}
	.sidebar-section:not([open]) .sidebar-folder-icon-open {
		display: none;
	}

	.terminal-sheet-backdrop.is-visible {
		opacity: 1;
		pointer-events: auto;
	}

	.terminal-sheet-surface {
		max-height: min(85dvh, calc(100dvh - 0.5rem));
		overscroll-behavior: contain;
		transform: translateY(100%);
		transition: transform 320ms cubic-bezier(0.32, 0.72, 0, 1);
		will-change: transform;
	}
	.terminal-sheet-panel.is-open .terminal-sheet-surface {
		transform: translateY(0);
	}

	.terminal-sheet-body {
		min-height: min(42dvh, 320px);
		max-height: min(65dvh, 560px);
	}
	@media (min-width: 640px) {
		.terminal-sheet-body {
			min-height: min(40dvh, 340px);
			max-height: min(62dvh, 580px);
		}
	}
	@media (prefers-reduced-motion: reduce) {
		.terminal-sheet-surface {
			transition-duration: 0.01ms;
		}
	}

	:global(html.terminal-open) {
		overflow: hidden;
	}
	@media (min-width: 1024px) {
		.terminal-sheet-body {
			min-height: min(36dvh, 360px);
			max-height: min(56dvh, 640px);
		}
	}
	@media (min-width: 1280px) {
		.terminal-sheet-body {
			max-height: min(52dvh, 680px);
		}
	}
</style>

<script>
	function initSidebar() {
		const panel = document.getElementById('minimal-sidebar-panel');
		const backdrop = document.getElementById('sidebar-backdrop');
		const openBtn = document.getElementById('sidebar-open');
		const closeBtn = document.getElementById('sidebar-close');

		if (!panel || !backdrop || !openBtn) return;

		const elPanel = panel;
		const elBackdrop = backdrop;
		const elOpenBtn = openBtn;

		const isLarge = () => window.matchMedia('(min-width: 1024px)').matches;

		function setOpen(open: boolean) {
			if (isLarge()) {
				elPanel.classList.remove('is-open');
				elBackdrop.classList.remove('is-visible');
				document.documentElement.classList.remove('sidebar-open');
				elOpenBtn.setAttribute('aria-expanded', 'false');
				return;
			}
			elPanel.classList.toggle('is-open', open);
			elBackdrop.classList.toggle('is-visible', open);
			document.documentElement.classList.toggle('sidebar-open', open);
			elOpenBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
		}

		elOpenBtn.addEventListener('click', () => {
			setOpen(!elPanel.classList.contains('is-open'));
		});

		closeBtn?.addEventListener('click', () => setOpen(false));

		elBackdrop.addEventListener('click', () => setOpen(false));

		document.addEventListener('keydown', (e) => {
			if (e.key === 'Escape' && elPanel.classList.contains('is-open')) setOpen(false);
		});

		window.addEventListener('resize', () => {
			if (isLarge()) setOpen(false);
		});

		elPanel.addEventListener('click', (e) => {
			const a = (e.target as HTMLElement | null)?.closest?.('a');
			if (!a || !elPanel.contains(a)) return;
			if (!isLarge()) setOpen(false);
		});
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initSidebar);
	} else {
		initSidebar();
	}
</script>

<script>
	function initTerminalToggle() {
		const toggleButton = document.getElementById('terminal-toggle');
		const sheet = document.getElementById('terminal-dropdown');
		const backdrop = document.getElementById('terminal-sheet-backdrop');
		const closeBtn = document.getElementById('terminal-sheet-close');

		if (!toggleButton || !sheet || !backdrop) return;

		const setOpen = (open: boolean) => {
			sheet.classList.toggle('is-open', open);
			backdrop.classList.toggle('is-visible', open);
			backdrop.setAttribute('aria-hidden', open ? 'false' : 'true');
			sheet.setAttribute('aria-hidden', open ? 'false' : 'true');
			toggleButton.setAttribute('aria-expanded', open ? 'true' : 'false');
			sheet.classList.toggle('pointer-events-none', !open);
			document.documentElement.classList.toggle('terminal-open', open);
		};

		toggleButton.addEventListener('click', (e) => {
			e.stopPropagation();
			setOpen(!sheet.classList.contains('is-open'));
		});

		closeBtn?.addEventListener('click', () => setOpen(false));

		backdrop.addEventListener('click', () => setOpen(false));

		document.addEventListener(
			'keydown',
			(e) => {
				if (e.key !== 'Escape' || !sheet.classList.contains('is-open')) return;
				e.preventDefault();
				e.stopPropagation();
				setOpen(false);
			},
			true
		);
	}

	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', initTerminalToggle);
	} else {
		initTerminalToggle();
	}
</script>
